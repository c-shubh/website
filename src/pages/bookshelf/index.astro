---
import FormattedDate from '@/components/FormattedDate.astro';
import Page from '@/layouts/Page.astro';
import { orderBy, type OmitStrict } from '@/utils';
import { Image } from 'astro:assets';
import books from './_data.json';

interface RawBook {
	title: string;
	subtitle?: string;
	author: string;
	start?: string;
	end?: string;
	image?: string;
}

interface BaseBook {
	title: string;
	subtitle?: string;
	author: string;
	image?: string;
}

interface InProgressBook extends BaseBook {
	status: 'reading';
	start: string;
}

interface ReadWithDateBook extends BaseBook {
	status: 'readWithDate';
	start: string;
	end: string;
}

interface ReadWithoutDateBook extends BaseBook {
	status: 'readWithoutDate';
}

type TaggedBook = InProgressBook | ReadWithDateBook | ReadWithoutDateBook;

books satisfies OmitStrict<TaggedBook, 'status'>[];

const inProgressBooks: InProgressBook[] = [];
const readBooksWithDate: ReadWithDateBook[] = [];
const readBooksWithoutDate: ReadWithoutDateBook[] = [];

for (const book of books as RawBook[]) {
	if (book.start && book.end) {
		readBooksWithDate.push({ ...book, status: 'readWithDate', start: book.start, end: book.end });
	} else if (book.start) {
		inProgressBooks.push({ ...book, status: 'reading', start: book.start });
	} else {
		readBooksWithoutDate.push({ ...book, status: 'readWithoutDate' });
	}
}

const finishedCount = readBooksWithDate.length + readBooksWithoutDate.length;

const sortedBooks: TaggedBook[] = [
	...orderBy(inProgressBooks, ['start', 'desc'], ['author'], ['title']),
	...orderBy(readBooksWithDate, ['end', 'desc'], ['author'], ['title']),
	...orderBy(readBooksWithoutDate, ['author'], ['title']),
];
---

<Page title={'Bookshelf'}>
	<p>
		<strong>{finishedCount}</strong>
		{finishedCount === 1 ? ' book' : ' books'} read
	</p>

	<ul class="grid min-[30rem]:grid-cols-2 sm:grid-cols-3 gap-4 md:gap-6 not-prose">
		{
			sortedBooks.map((book) => (
				<li class="card card-sm shadow-sm">
					{book.image ? (
						<figure>
							<Image
								src={book.image}
								alt={`Cover of ${book.title} - ${book.author}`}
								width={229}
								height={343}
								loading={'lazy'}
								class="w-full"
							/>
						</figure>
					) : null}
					<div class="card-body">
						{book.status === 'reading' ? (
							<span class="badge badge-sm badge-primary font-medium">Reading</span>
						) : null}
						<span class="card-title">{book.title}</span>
						{book.subtitle ? <p class="grow-0">{book.subtitle}</p> : null}
						<p class="text-sm font-medium">{book.author}</p>

						<div class="mt-4 pt-3 border-t border-base-200 flex flex-col gap-1">
							<p class="text-xs text-base-content/70">
								{'start' in book && book.start ? (
									<>
										<span class="font-semibold">Started:</span>{' '}
										<FormattedDate date={new Date(book.start)} />
									</>
								) : (
									<br />
								)}
							</p>
							<p class="text-xs text-base-content/70">
								{'end' in book && book.end ? (
									<>
										<span class="font-semibold">Finished:</span>{' '}
										<FormattedDate date={new Date(book.end)} />
									</>
								) : (
									<br />
								)}
							</p>
						</div>
					</div>
				</li>
			))
		}
	</ul>
</Page>
