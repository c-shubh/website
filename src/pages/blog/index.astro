---
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="space-y-4">
    {
      posts.map((post) => (
        <div class="flex flex-col sm:flex-row sm:items-start gap-0.5 sm:gap-4 ">
          <FormattedDate
            date={post.data.date}
            className="text-nowrap font-mono text-xs sm:text-base"
          />
          <a href={`/blog/${post.id}/`} class="no-underline hover:underline">
            <h4 class="m-0">{post.data.title}</h4>
          </a>
        </div>
      ))
    }
  </section>
</Layout>
