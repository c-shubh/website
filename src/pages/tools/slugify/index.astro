---
import Page from '@/layouts/Page.astro';
import { toolsMap } from '@/pages/tools/_data';
import { Slugify } from './_Slugify.tsx';

const { name, description } = toolsMap['slugify'];
---

<Page title={name} description={description}>
	<p>Enter text below. Each line will be converted to a slug.</p>
	<Slugify client:load />
</Page>
