---
import ClientOnlyFallback from '@/components/ClientOnlyFallback.astro';
import Page from '@/layouts/Page.astro';
import { toolsMap } from '@/pages/tools/_data';
import { WordCount } from './_WordCount.tsx';

const { name, description } = toolsMap['word-count'];
---

<Page title={name} description={description}>
	<p>Enter text below or select a file to see character, word and line count.</p>
	<WordCount client:only="react">
		<div slot="fallback">
			<ClientOnlyFallback />
		</div>
	</WordCount>
</Page>
