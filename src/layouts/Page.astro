---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface HomePage {
	layout: 'home';
}

interface BlogPage {
	layout: 'blog';
	title: string;
	date: Date;
}

interface Page {
	layout?: 'page';
	title: string;
}

type Props = HomePage | BlogPage | Page;

const props: Props = Astro.props;
props.layout = props.layout ?? 'page';
---

<!doctype html>
<html lang="en">
	<head>
		{props.layout === 'home' && <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />}
		{props.layout === 'page' && <BaseHead title={props.title} />}
		{props.layout === 'blog' && <BaseHead title={props.title} />}
	</head>
	<body>
		<div class="flex flex-col min-h-screen m-0 font-sans max-w-2xl px-4 mx-auto leading-relaxed">
			<Header />
			<main class="flex-grow">
				{
					props.layout === 'blog' ? (
						<article>
							<div>
								<h1 class="my-0">{props.title}</h1>
								{props.date && (
									<div>
										<span class="font-medium">
											<FormattedDate date={props.date} />
										</span>
									</div>
								)}
							</div>
							<div>
								<slot />
							</div>
						</article>
					) : (
						<>
							{props.layout === 'page' && <h1 class="mt-0">{props.title}</h1>}
							<slot />
						</>
					)
				}
			</main>
			<Footer />
		</div>
	</body>
</html>
