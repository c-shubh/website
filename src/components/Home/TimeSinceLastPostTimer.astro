---
import { clsx } from '@/utils';

interface Props {
	lastPostDate: string | Date;
	className?: string | null;
}

const { lastPostDate, className } = Astro.props;
---

<dl
	class={clsx('flex gap-5 not-prose', className)}
	id="time-since-last-post-timer"
	data-last-post={new Date(lastPostDate).toISOString()}
>
	<div>
		<dd class="countdown font-mono text-4xl">
			<span id="time-since-last-post-days" style="--value:0;">0</span>
		</dd>
		days
	</div>
	<div>
		<dd class="countdown font-mono text-4xl">
			<span id="time-since-last-post-hours" style="--value:0;">0</span>
		</dd>
		hours
	</div>
	<div>
		<dd class="countdown font-mono text-4xl">
			<span id="time-since-last-post-mins" style="--value:0;">0</span>
		</dd>
		min
	</div>
	<div>
		<dd class="countdown font-mono text-4xl">
			<span id="time-since-last-post-secs" style="--value:0;">0</span>
		</dd>
		sec
	</div>
</dl>

<script>
	const timerElement = document.getElementById('time-since-last-post-timer')!;
	const dateString = timerElement.getAttribute('data-last-post')!;

	const startDate = new Date(dateString).getTime();

	const elDays = document.getElementById('time-since-last-post-days')!;
	const elHours = document.getElementById('time-since-last-post-hours')!;
	const elMins = document.getElementById('time-since-last-post-mins')!;
	const elSecs = document.getElementById('time-since-last-post-secs')!;

	function updateTimer() {
		const now = new Date().getTime();
		const diff = Math.max(0, now - startDate);

		const d = Math.floor(diff / (1000 * 60 * 60 * 24));
		const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
		const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
		const s = Math.floor((diff % (1000 * 60)) / 1000);

		for (const [el, t] of [
			[elDays, d],
			[elHours, h],
			[elMins, m],
			[elSecs, s],
		] as const) {
			el.textContent = t.toString();
			el.style.setProperty('--value', t.toString());
		}
	}

	updateTimer();
	setInterval(updateTimer, 1000);
</script>
