---

<div class="flex flex-row flex-wrap justify-center gap-2 w-fit mx-auto">
	{
		badges.map((badge) => {
			if (badge.type === 'image') {
				const badgeImage =
					typeof badge.src === 'string' ? (
						<Image src={badge.src} alt={badge.alt} id={badge.id} width={88} height={31} />
					) : (
						<Image src={badge.src} alt={badge.alt} id={badge.id} />
					);

				return badge.href ? <Link href={badge.href}>{badgeImage}</Link> : badgeImage;
			}
			if (badge.type === 'component') {
				const Component = badge.component;
				return <Component />;
			}
		})
	}
</div>

<script>
	import confetti from 'canvas-confetti';

	const count = 200;
	const defaults = {
		origin: { y: 0.7 },
	};

	function fire(particleRatio: number, opts: any) {
		confetti({
			...defaults,
			...opts,
			particleCount: Math.floor(count * particleRatio),
		});
	}

	const footerClickHereBadge = document.getElementById('footer-click-here-badge');

	footerClickHereBadge?.addEventListener('click', () => {
		fire(0.25, {
			spread: 26,
			startVelocity: 55,
		});
		fire(0.2, {
			spread: 60,
		});
		fire(0.35, {
			spread: 100,
			decay: 0.91,
			scalar: 0.8,
		});
		fire(0.1, {
			spread: 120,
			startVelocity: 25,
			decay: 0.92,
			scalar: 1.2,
		});
		fire(0.1, {
			spread: 120,
			startVelocity: 45,
		});
	});

	const footerPokeBadge = document.getElementById('footer-poke-badge');
	const pokeContainer = document.body;

	footerPokeBadge?.addEventListener('click', () => {
		pokeContainer.classList.remove('animate-poke-right');
		// reflow page: https://stackoverflow.com/questions/60686489/what-purpose-does-void-element-offsetwidth-serve
		void pokeContainer.offsetWidth;
		pokeContainer.classList.add('animate-poke-right');

		setTimeout(() => {
			pokeContainer.classList.remove('animate-poke-right');
			// 400ms (same as animation duration)
		}, 400);
	});
</script>
