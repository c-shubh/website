---
import noAiWidget0 from '@/assets/images/baccyflap-com-noai-valywidget0.gif';
import noAiWidget1 from '@/assets/images/baccyflap-com-noai-valywidget1.gif';
import noAiWidget2 from '@/assets/images/baccyflap-com-noai-valywidget2.gif';
import noAiWidget3 from '@/assets/images/baccyflap-com-noai-valywidget3.gif';
import gliderSvg from '@/assets/images/glider.svg';
import { COPYRIGHT } from '@/consts';
import { Image } from 'astro:assets';
import Link from './Link.astro';
---

<footer class="my-4 text-center">
	<hr class="mt-10 mb-4" id="oneko-floor" />
	<div>
		<a href="https://baccyflap.com/noai/?prv&s=csh" target="_top"
			><Image
				src={noAiWidget0}
				alt="previous no ai webring site"
				title="previous no ai webring site"
			/></a
		><a href="https://baccyflap.com/noai" target="_blank"
			><Image src={noAiWidget1} alt="no ai webring" title="no ai webring" /></a
		><a href="https://baccyflap.com/noai/?rnd" target="_top"
			><Image
				src={noAiWidget2}
				alt="random no ai webring site"
				title="random no ai webring site"
			/></a
		><a href="https://baccyflap.com/noai/?nxt&s=csh" target="_top"
			><Image src={noAiWidget3} alt="next no ai webring site" title="next no ai webring site" /></a
		>
	</div>
	<span class="flex items-center justify-center gap-1">
		<span>
			{COPYRIGHT.symbol}{' '}{COPYRIGHT.year}
			{COPYRIGHT.holder}
		</span>
		<Link href={'http://www.catb.org/hacker-emblem/'} class={'flex items-center justify-center'}>
			<Image src={gliderSvg} alt="Glider" class="inline h-4 w-4 border-0" />
		</Link>
	</span>
	<span>
		{COPYRIGHT.string}
	</span>
</footer>

<script>
	// oneko.js: https://github.com/adryd325/oneko.js

	const OnekoConfig = {
		SPRITE_SIZE: 32,
		SPRITE_HALF_SIZE: 16,
		Z_INDEX: '2147483647',

		DEFAULT_SPEED: 10,
		CATCH_DISTANCE: 48,
		DIRECTION_THRESHOLD: 0.5,

		FRAME_RATE_MS: 100,

		// in frame ticks
		WAKE_UP_DURATION: 8,
		ALERT_DURATION: 7,
		IDLE_WAIT_DELAY: 10,

		IDLE_ANIM_CHANCE: 50,
		SLEEP_FRAME_DIVISOR: 4,
		SLEEP_MAX_FRAMES: 192,
		DEFAULT_ANIM_MAX_FRAMES: 9,
	} as const;

	interface OnekoConstructorProps {
		nekoFile: string;
	}

	interface CatState {
		enter?: (cat: Oneko) => void;
		update: (cat: Oneko, distance: number) => void;
		exit?: (cat: Oneko) => void;
	}

	class Oneko {
		nekoPosX: number = OnekoConfig.SPRITE_SIZE;
		nekoPosY: number = OnekoConfig.SPRITE_SIZE;
		mousePosX = 0;
		mousePosY = 0;
		nekoSpeed = OnekoConfig.DEFAULT_SPEED;

		currentState: CatState | null = null;
		stateTimer = 0;
		frameCount = 0;

		idleAnimation: keyof typeof this.spriteSets | null = null;
		idleAnimationFrame = 0;

		nekoEl = document.createElement('div');
		lastFrameTimestamp: number | undefined;
		nekoFile: string;

		spriteSets = {
			idle: [[-3, -3]],
			alert: [[-7, -3]],
			scratchSelf: [
				[-5, 0],
				[-6, 0],
				[-7, 0],
			],
			scratchWallN: [
				[0, 0],
				[0, -1],
			],
			scratchWallS: [
				[-7, -1],
				[-6, -2],
			],
			scratchWallE: [
				[-2, -2],
				[-2, -3],
			],
			scratchWallW: [
				[-4, 0],
				[-4, -1],
			],
			tired: [[-3, -2]],
			sleeping: [
				[-2, 0],
				[-2, -1],
			],
			N: [
				[-1, -2],
				[-1, -3],
			],
			NE: [
				[0, -2],
				[0, -3],
			],
			E: [
				[-3, 0],
				[-3, -1],
			],
			SE: [
				[-5, -1],
				[-5, -2],
			],
			S: [
				[-6, -3],
				[-7, -2],
			],
			SW: [
				[-5, -3],
				[-6, -1],
			],
			W: [
				[-4, -2],
				[-4, -3],
			],
			NW: [
				[-1, 0],
				[-1, -1],
			],
		};

		private states = {
			SLEEPING: {
				enter: (cat) => {
					cat.nekoEl.style.cursor = 'pointer';
					cat.nekoEl.style.pointerEvents = 'auto';
					cat.idleAnimationFrame = 0;
				},
				update: (cat) => {
					cat.setSprite(
						'sleeping',
						Math.floor(cat.idleAnimationFrame / OnekoConfig.SLEEP_FRAME_DIVISOR)
					);
					cat.idleAnimationFrame++;
				},
				exit: (cat) => {
					cat.nekoEl.style.cursor = 'default';
					cat.nekoEl.style.pointerEvents = 'none';
					cat.nekoEl.style.position = 'fixed';
					cat.nekoPosY = cat.nekoPosY - window.scrollY;
					cat.nekoEl.style.top = `${cat.nekoPosY - OnekoConfig.SPRITE_HALF_SIZE}px`;
				},
			},

			WAKING_UP: {
				enter: (cat) => {
					cat.setSprite('tired', 0);
					cat.stateTimer = OnekoConfig.WAKE_UP_DURATION;
				},
				update: (cat) => {
					cat.stateTimer--;
					if (cat.stateTimer <= 0) {
						cat.transitionTo('ALERT');
					}
				},
			},

			ALERT: {
				enter: (cat) => {
					cat.setSprite('alert', 0);
					cat.stateTimer = OnekoConfig.ALERT_DURATION;
				},
				update: (cat, distance) => {
					cat.stateTimer--;
					if (cat.stateTimer <= 0) {
						if (distance < cat.nekoSpeed || distance < OnekoConfig.CATCH_DISTANCE) {
							cat.transitionTo('IDLE');
						} else {
							cat.transitionTo('MOVING');
						}
					}
				},
			},

			IDLE: {
				enter: (cat) => {
					cat.stateTimer = 0;
					cat.idleAnimation = null;
					cat.idleAnimationFrame = 0;
				},
				update: (cat, distance) => {
					if (distance > OnekoConfig.CATCH_DISTANCE) {
						cat.transitionTo('ALERT');
						return;
					}

					cat.stateTimer++;

					if (
						cat.stateTimer > OnekoConfig.IDLE_WAIT_DELAY &&
						Math.floor(Math.random() * OnekoConfig.IDLE_ANIM_CHANCE) === 0 &&
						cat.idleAnimation === null
					) {
						let availableAnimations: (keyof typeof cat.spriteSets)[] = ['sleeping', 'scratchSelf'];
						if (cat.nekoPosX < OnekoConfig.SPRITE_SIZE) availableAnimations.push('scratchWallW');
						if (cat.nekoPosY < OnekoConfig.SPRITE_SIZE) availableAnimations.push('scratchWallN');
						if (cat.nekoPosX > window.innerWidth - OnekoConfig.SPRITE_SIZE)
							availableAnimations.push('scratchWallE');
						if (cat.nekoPosY > window.innerHeight - OnekoConfig.SPRITE_SIZE)
							availableAnimations.push('scratchWallS');

						cat.idleAnimation =
							availableAnimations[Math.floor(Math.random() * availableAnimations.length)];
					}

					if (cat.idleAnimation) {
						switch (cat.idleAnimation) {
							case 'sleeping':
								cat.setSprite(
									'sleeping',
									Math.floor(cat.idleAnimationFrame / OnekoConfig.SLEEP_FRAME_DIVISOR)
								);
								if (cat.idleAnimationFrame > OnekoConfig.SLEEP_MAX_FRAMES) {
									cat.idleAnimation = null;
									cat.idleAnimationFrame = 0;
								}
								break;
							default:
								cat.setSprite(cat.idleAnimation, cat.idleAnimationFrame);
								if (cat.idleAnimationFrame > OnekoConfig.DEFAULT_ANIM_MAX_FRAMES) {
									cat.idleAnimation = null;
									cat.idleAnimationFrame = 0;
								}
								break;
						}
						cat.idleAnimationFrame++;
					} else {
						cat.setSprite('idle', 0);
					}
				},
			},

			MOVING: {
				update: (cat, distance) => {
					if (distance < cat.nekoSpeed || distance < OnekoConfig.CATCH_DISTANCE) {
						cat.transitionTo('IDLE');
						return;
					}

					cat.frameCount++;
					const diffX = cat.nekoPosX - cat.mousePosX;
					const diffY = cat.nekoPosY - cat.mousePosY;

					let direction = diffY / distance > OnekoConfig.DIRECTION_THRESHOLD ? 'N' : '';
					direction += diffY / distance < -OnekoConfig.DIRECTION_THRESHOLD ? 'S' : '';
					direction += diffX / distance > OnekoConfig.DIRECTION_THRESHOLD ? 'W' : '';
					direction += diffX / distance < -OnekoConfig.DIRECTION_THRESHOLD ? 'E' : '';

					if (direction in cat.spriteSets) {
						cat.setSprite(direction as keyof typeof cat.spriteSets, cat.frameCount);
					}

					cat.nekoPosX -= (diffX / distance) * cat.nekoSpeed;
					cat.nekoPosY -= (diffY / distance) * cat.nekoSpeed;

					cat.nekoPosX = Math.min(
						Math.max(OnekoConfig.SPRITE_HALF_SIZE, cat.nekoPosX),
						window.innerWidth - OnekoConfig.SPRITE_HALF_SIZE
					);
					cat.nekoPosY = Math.min(
						Math.max(OnekoConfig.SPRITE_HALF_SIZE, cat.nekoPosY),
						window.innerHeight - OnekoConfig.SPRITE_HALF_SIZE
					);

					cat.nekoEl.style.left = `${cat.nekoPosX - OnekoConfig.SPRITE_HALF_SIZE}px`;
					cat.nekoEl.style.top = `${cat.nekoPosY - OnekoConfig.SPRITE_HALF_SIZE}px`;
				},
			},
		} satisfies Record<string, CatState>;

		constructor({ nekoFile }: OnekoConstructorProps) {
			this.nekoFile = nekoFile;
			this.transitionTo('SLEEPING');
		}

		transitionTo(stateName: keyof typeof this.states) {
			if (this.currentState?.exit) {
				this.currentState.exit(this);
			}

			this.currentState = this.states[stateName];

			if (this.currentState.enter) {
				this.currentState.enter(this);
			}
		}

		private setSprite(name: keyof typeof this.spriteSets, frame: number) {
			const sprite = this.spriteSets[name][frame % this.spriteSets[name].length];
			this.nekoEl.style.backgroundPosition = `${sprite[0] * OnekoConfig.SPRITE_SIZE}px ${sprite[1] * OnekoConfig.SPRITE_SIZE}px`;
		}

		private onAnimationFrame = (timestamp: number) => {
			if (!this.nekoEl.isConnected) return;

			if (!this.lastFrameTimestamp) this.lastFrameTimestamp = timestamp;

			if (timestamp - this.lastFrameTimestamp > OnekoConfig.FRAME_RATE_MS) {
				this.lastFrameTimestamp = timestamp;

				const diffX = this.nekoPosX - this.mousePosX;
				const diffY = this.nekoPosY - this.mousePosY;
				const distance = Math.sqrt(diffX ** 2 + diffY ** 2);

				if (this.currentState) {
					this.currentState.update(this, distance);
				}
			}
			window.requestAnimationFrame(this.onAnimationFrame);
		};

		init() {
			if (window.matchMedia(`(prefers-reduced-motion: reduce)`).matches) return;

			const floorEl = document.getElementById('oneko-floor');
			if (floorEl) {
				const rect = floorEl.getBoundingClientRect();

				this.nekoPosX = rect.left + rect.width / 2;
				this.nekoPosY = window.scrollY + rect.top - OnekoConfig.SPRITE_HALF_SIZE;
			}

			this.nekoEl.id = 'oneko';
			this.nekoEl.ariaHidden = 'true';
			this.nekoEl.style.width = `${OnekoConfig.SPRITE_SIZE}px`;
			this.nekoEl.style.height = `${OnekoConfig.SPRITE_SIZE}px`;
			this.nekoEl.style.position = 'absolute';
			this.nekoEl.style.imageRendering = 'pixelated';
			this.nekoEl.style.left = `${this.nekoPosX - OnekoConfig.SPRITE_HALF_SIZE}px`;
			this.nekoEl.style.top = `${this.nekoPosY - OnekoConfig.SPRITE_HALF_SIZE}px`;
			this.nekoEl.style.zIndex = OnekoConfig.Z_INDEX;
			this.nekoEl.style.backgroundImage = `url(${this.nekoFile})`;

			this.nekoEl.addEventListener('click', () => {
				if (this.currentState === this.states['SLEEPING']) {
					this.transitionTo('WAKING_UP');
				}
			});

			document.body.appendChild(this.nekoEl);

			document.addEventListener('mousemove', (event) => {
				this.mousePosX = event.clientX;
				this.mousePosY = event.clientY;
			});

			window.requestAnimationFrame(this.onAnimationFrame);
		}
	}

	const oneko = new Oneko({ nekoFile: '/images/oneko.gif' });
	oneko.init();
</script>
