---
import rssIcon from '@/assets/images/Feed-icon.svg';

import Link from '@/components/Link.astro';
import { BLOG_RSS_FEED } from '@/consts';
import type { SlashPage } from '@/slashPages';
import { Image } from 'astro:assets';

interface Props {
	links: SlashPage[];
}

const { links } = Astro.props;
---

{
	links.map((link) => (
		<li>
			<Link href={link.href}>{link.name}</Link>
		</li>
	))
}
<li>
	<Link href={BLOG_RSS_FEED} title={'RSS Feed'}>
		<Image src={rssIcon} alt="RSS Feed" width={20} />
	</Link>
</li>
